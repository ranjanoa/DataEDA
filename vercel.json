{
  "version": 2,
  "outputDirectory": ".",
  "functions": {
    "api/index.py": {
      "includeFiles": "frontend/**",
      "excludeFiles": "{.venv,node_modules,backend}/**"
    }
  },
  "rewrites": [
    {
      "source": "/static/(.*)",
      "destination": "/frontend/static/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ]
}
